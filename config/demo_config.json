{
  "camera": {
    "name": "poe-camera-1",
    "source": "rtsp://admin:@192.168.3.10/Streaming/Channels/101",
    "use_gstreamer": true,
    "notes": "use_gstreamer enables Jetson NVDEC hardware decode, set false to fall back to CPU"
  },
  "detector": {
    "backend": "yolov5_trt",
    "onnx_file": "yolo26n.onnx",
    "conf_threshold": 0.35,
    "iou_threshold": 0.45,
    "fp16": true,
    "infer_interval": 1,
    "notes": "infer_interval=1 with TRT GPU is fast enough for every-frame inference"
  },
  "tracker": {
    "max_distance": 90,
    "max_age_seconds": 1.5
  },
  "rules": {
    "event_cooldown_seconds": 8,
    "zones": [],
    "lines": []
  },
  "output": {
    "root": "/app/output",
    "save_snapshots": true
  },
  "display": {
    "show_window": true,
    "window_name": "Industrial Security Demo",
    "resize_width": 1280
  },
  "web": {
    "port": 8080
  }
}