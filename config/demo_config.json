{
  "cameras": {
    "mode": "manual",
    "auto_discover": {
      "subnet": "192.168.3.0/24",
      "username": "admin",
      "password": "",
      "rtsp_paths": [
        "/Streaming/Channels/101",
        "/Streaming/Channels/1"
      ],
      "scan_interval_seconds": 30
    },
    "manual": [
      {
        "id": "cam-0",
        "name": "poe-camera-1",
        "source": "rtsp://admin:@192.168.3.10/Streaming/Channels/101",
        "use_gstreamer": true,
        "enabled": true
      },
      {
        "id": "cam-1",
        "name": "poe-camera-2",
        "source": "rtsp://admin:@192.168.3.20/Streaming/Channels/101",
        "use_gstreamer": true,
        "enabled": true
      }
    ]
  },
  "detector": {
    "backend": "yolov5_trt",
    "onnx_file": "yolo26n.onnx",
    "conf_threshold": 0.35,
    "iou_threshold": 0.45,
    "fp16": true,
    "infer_interval": 1,
    "notes": "infer_interval=1 with TRT GPU is fast enough for every-frame inference"
  },
  "tracker": {
    "max_distance": 90,
    "max_age_seconds": 1.5
  },
  "rules": {
    "event_cooldown_seconds": 8,
    "zones": [],
    "lines": []
  },
  "output": {
    "root": "output",
    "save_snapshots": true
  },
  "display": {
    "show_window": true,
    "window_name": "Industrial Security Demo",
    "resize_width": 1280,
    "web_jpeg_quality": 50
  },
  "web": {
    "port": 8080
  }
}